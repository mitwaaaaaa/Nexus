# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=researchos
DATABASE_URL=postgresql://postgres:postgres@db:5432/researchos

# Security Settings
JWT_SECRET=super_secret_jwt_signing_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Vector DB Settings
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# AI Provider Keys (At least one is required)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
DEFAULT_LLM_MODEL=gpt-4o-mini # or gemini-1.5-flash

# Application Settings
ENVIRONMENT=development
APP_NAME=Nexus
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
